{
  "name": "@armature/forge-cli",
  "version": "0.1.0",
  "description": "Forge CLI — provider-neutral agent runtime with Claude Code depth",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "forge": "./dist/bin/forge.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "lint": "tsc --noEmit",
    "dev": "tsc --watch",
    "bench": "node dist/bin/forge.js bench",
    "prepublishOnly": "npm run build && npm test && npm run bench"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "https-proxy-agent": "^7.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "openai": "^6.33.0",
    "undici": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli",
    "agent",
    "coding-agent",
    "forge",
    "multi-model",
    "poe",
    "openai",
    "claude",
    "gemini",
    "gpt",
    "benchmark"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MARUCIE/forge-cli.git"
  },
  "homepage": "https://github.com/MARUCIE/forge-cli",
  "license": "MIT",
  "author": {
    "name": "Maurice",
    "email": "maurice_wen@proton.me"
  }
}
